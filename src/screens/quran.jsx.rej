+        const cx = Math.min(W - 130, Math.max(130, ayahMenu.x));
+        const top = ayahMenu.y - 8 < 150 ? ayahMenu.y + 24 : ayahMenu.y - 8;
+        const isSaved = savedSet.has(ayahMenu.ch + ':' + ayahMenu.vno);
+        const Item = ({ label, onClick, soon, danger }) => (
+          <button onClick={(e) => { e.stopPropagation(); onClick(); }} className="afn-tap"
