+            {soon && <span style={{ fontFamily: T.fBody, fontSize: 11, fontWeight: 700, color: '#fff',
+              background: T.gold, borderRadius: 99, padding: '2px 9px' }}>{window.t('qp_soon')}</span>}
+          </button>
+        );
+        return (
+          <div onClick={() => setAyahMenu(null)} style={{ position: 'absolute', inset: 0, zIndex: 60 }}>
