+              border: 'none', borderBottom: `1px solid ${T.line}`, background: 'transparent', cursor: 'pointer',
+              padding: '12px 16px', fontFamily: T.fHead, fontSize: 15, fontWeight: 700,
+              color: danger ? '#B5482F' : T.ink }}>
