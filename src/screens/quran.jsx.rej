+      })()}
+
+      {/* الواجهة العائمة — ضغطة واحدة */}
+      {menu && (
+        <div onClick={() => setMenu(false)} style={{ position: 'absolute', inset: 0, zIndex: 55,
+          background: 'rgba(20,38,30,.34)', display: 'flex', alignItems: 'center', justifyContent: 'center',
