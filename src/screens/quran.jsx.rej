+          <svg width="26" height="40" viewBox="0 0 26 40">
+            <path d="M0 0h26v40l-13-9-13 9V0Z" fill={T.gold} stroke="#A9822F" strokeWidth="1" />
+            <path d="M13 9l3.2 6.5 7.1 1-5.1 5 1.2 7.1L13 31.3 6.6 34.6l1.2-7.1-5.1-5 7.1-1L13 9Z" fill="#FBF4DF" opacity="0.55" />
+          </svg>
+        </div>
+      )}
+
+      <div className="afn-scroll" style={{ flex: 1, minHeight: 0, overflowY: 'auto', overflowX: 'hidden',
+        padding: '42px 18px 26px', display: 'flex', flexDirection: 'column' }}>
+        {loading && (
+          <div style={{ margin: 'auto', textAlign: 'center', padding: '60px 20px' }}>
+            <div style={{ display: 'inline-flex', gap: 7 }}>
+              {[0,1,2].map(i => <span key={i} style={{ width: 11, height: 11, borderRadius: '50%', background: T.green2,
+                animation: `afn-pulse 1s ease-in-out ${i*0.2}s infinite` }} />)}
+            </div>
+            <div style={{ fontFamily: T.fBody, fontSize: 14.5, color: T.inkMuted, marginTop: 18 }}>{window.t('qp_loading')}</div>
+          </div>
+        )}
+        {error && (
+          <div style={{ margin: 'auto', textAlign: 'center', padding: '60px 24px' }}>
+            <Icon name="book" size={40} color={T.mintEdge} />
+            <div style={{ fontFamily: T.fHead, fontSize: 17, fontWeight: 600, color: T.ink, marginTop: 14 }}>{window.t('qp_err')}</div>
+            <div style={{ fontFamily: T.fBody, fontSize: 13.5, color: T.inkMuted, marginTop: 6 }}>{window.t('q_err_check')}</div>
+            <button onClick={() => { delete _pageCache[page]; setError(false); setLoading(true);
+              fetchMushafPage(page).then(m => { setModel(m); setLoading(false); }).catch(() => { setError(true); setLoading(false); }); }}
+              className="afn-tap" style={{ marginTop: 18, border: 'none', cursor: 'pointer', padding: '11px 24px', borderRadius: 14,
+              fontFamily: T.fHead, fontSize: 15, fontWeight: 700, background: T.green, color: '#fff' }}>{window.t('btn_retry')}</button>
+          </div>
+        )}
+
+        {!loading && !error && model && (
+          <div key={page} style={{ flex: 1, display: 'flex', flexDirection: 'column', justifyContent: 'center',
+            animation: 'afn-fade .25s ease both', maxWidth: 560, width: '100%', margin: '0 auto' }}>
+            {model.lines.map((ln, li) => {
+              const startCh = ln.startCh;
+              const meta = startCh ? SURAH_INDEX[startCh - 1] : null;
+              return (
+                <React.Fragment key={li}>
+                  {meta && <SurahBanner name={window.surahName(startCh, meta.name)} />}
+                  {meta && startCh !== 1 && startCh !== 9 && (
+                    <div style={{ textAlign: 'center', padding: '4px 30px 6px' }}>
+                      <img src="assets/zakharif/basmala.png" alt="بسم الله الرحمن الرحيم"
+                        style={{ width: '64%', maxWidth: 240, height: 'auto', display: 'block', margin: '0 auto', opacity: 0.9 }} />
+                    </div>
+                  )}
+                  <p dir="rtl" style={{ margin: 0, fontFamily: T.fQuran, fontSize: fontSize,
+                    lineHeight: page === 1 ? 2.5 : 2.05, color: TJ.base,
+                    textAlign: ln.center ? 'center' : 'justify',
+                    textAlignLast: ln.center ? 'center' : 'justify', whiteSpace: 'normal' }}>
+                    {ln.items.map((it, ii) => {
+                      if (it.type === 'end') {
+                        const active = savedSet.has(it.ch + ':' + it.vno);
+                        return <AyahMark key={ii} n={it.vno} size={fontSize} active={active} onTap={() => {}} />;
+                      }
+                      const active = savedSet.has(it.ch + ':' + it.vno);
+                      return (
+                        <React.Fragment key={ii}>
+                          <span style={active ? { background: 'rgba(201,162,75,.14)', borderRadius: 5 } : null}>
+                            <Word seg={it.seg} active={false} onTap={() => {}}
+                              onPressStart={(e) => startLP(it.ch, it.vno, e)} onPressMove={moveLP} onPressEnd={endLP} />
+                          </span>
+                          {' '}
+                        </React.Fragment>
+                      );
+                    })}
+                  </p>
+                </React.Fragment>
+              );
+            })}
+            {/* رقم الصفحة والجزء أسفلها — كالمصحف */}
+            <div style={{ display: 'flex', alignItems: 'center', gap: 12, margin: '20px auto 0', maxWidth: 320, width: '100%' }}>
+              <span style={{ flex: 1, height: 1, background: T.goldSoft }} />
+              <span style={{ fontFamily: T.fHead, fontSize: 14, fontWeight: 700, color: T.green }}>{window.tnum(page)}</span>
+              {model.juz && <React.Fragment>
+                <span style={{ width: 3, height: 3, borderRadius: 99, background: T.gold }} />
+                <span style={{ fontFamily: T.fBody, fontSize: 10.5, fontWeight: 700, color: T.bark }}>{window.t('q_juz')} {window.AFN_LANG === 'ar' ? JUZ_NAMES[model.juz] : window.tnum(model.juz)}</span>
+              </React.Fragment>}
+              <span style={{ flex: 1, height: 1, background: T.goldSoft }} />
+            </div>
+          </div>
+        )}
+      </div>
+
+      {/* قائمة الآية — الضغط المطوّل */}
+      {ayahMenu && (() => {
