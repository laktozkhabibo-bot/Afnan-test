-function QuranScreen({ active, openSurah, jumpAyah, onOpenSurah, onCloseSurah, fontScale, qiraah, translation, bookmark, onBookmark, saved, setSaved, seenIntro, onSeenIntro, khatmat, setKhatmat, userName }) {
+// ════════════════════════════════════════════════════════════════════════
+// نظام صفحات المصحف — عرضٌ صفحةً صفحة مطابقٌ لمصحف المدينة (٦٠٤ صفحات)
+// التوزيع السطريّ مأخوذ من بيانات مصحف المدينة (QPC) عبر quran.com:
+//   verses/by_page → كلماتٌ موسومةٌ برقم السطر، فيُعاد بناء أسطر الصفحة كما طُبعت
+// ════════════════════════════════════════════════════════════════════════
+
+// صفحة بداية كلّ سورة في مصحف المدينة (الفهرس المعتمد ١–١١٤)
+const SURAH_START_PAGE = [0,
+  1,2,50,77,106,128,151,177,187,208,221,235,249,255,262,267,282,293,305,312,
+  322,332,342,350,359,367,377,385,396,404,411,415,418,428,434,440,446,453,458,467,
+  477,483,489,496,499,502,507,511,515,518,520,523,526,528,531,534,537,542,545,549,
+  551,553,554,556,558,560,562,564,566,568,570,572,574,575,577,578,580,582,583,585,
+  586,587,587,589,590,591,591,592,593,594,595,595,596,596,597,597,598,598,599,599,
+  600,600,601,601,601,602,602,602,603,603,603,604,604,604];
+const MUSHAF_LAST_PAGE = 604;
+
+const _pageCache = {};   // page → نموذج الصفحة المبنيّ
+// يبني نموذج صفحةٍ من آيات quran.com: أسطرٌ مرتّبة + بدايات السور + نصوص الآيات
+function buildPageModel(verses, pageNum) {
+  const lineMap = {};            // رقم السطر → عناصر السطر
+  const surahStartLine = {};     // رقم السورة → أوّل سطرٍ تظهر فيه
+  const surahLastLine = {};      // رقم السورة → آخر سطرٍ تنتهي عنده (لتوسيط السطر الأخير)
+  const verseText = {};          // مفتاح الآية → نصّها كاملاً (للحفظ والتفسير)
+  let juz = verses && verses[0] ? verses[0].juz_number : null;
+  let minLine = 99, maxLine = 0;
+  (verses || []).forEach(v => {
+    const ch = v.chapter_id, vno = v.verse_number;
+    const words = v.words || [];
+    const textWords = words.filter(w => w.char_type_name === 'word');
+    verseText[ch + ':' + vno] = textWords.map(w => w.text_uthmani || '').join(' ');
+    let colored;
+    try { colored = colorizeAyah(textWords.map(w => ({ t: w.text_uthmani || '' }))); }
+    catch (e) { colored = textWords.map(w => [{ t: w.text_uthmani || '', c: TJ.base }]); }
+    let wi = 0;
+    words.forEach(w => {
+      const ln = w.line_number || 1;
+      if (ln < minLine) minLine = ln;
+      if (ln > maxLine) maxLine = ln;
+      (lineMap[ln] || (lineMap[ln] = []));
+      if (w.char_type_name === 'word') {
+        lineMap[ln].push({ type: 'word', ch, vno, seg: colored[wi] || [{ t: w.text_uthmani || '', c: TJ.base }] });
+        wi++;
+      } else if (w.char_type_name === 'end') {
+        lineMap[ln].push({ type: 'end', ch, vno });
+      }
+      surahLastLine[ch] = Math.max(surahLastLine[ch] || 0, ln);
+    });
+    if (vno === 1) {
+      const fl = Math.min.apply(null, words.map(w => w.line_number || 99));
+      surahStartLine[ch] = fl;
+    }
+  });
+  // أسطرٌ ينبغي توسيطها: آخر سطرٍ لسورةٍ انتهت فعلاً داخل هذه الصفحة
+  const centerLines = new Set();
+  (verses || []).forEach(v => {
+    const meta = SURAH_INDEX[v.chapter_id - 1];
+    if (meta && v.verse_number === meta.ayahs) centerLines.add(surahLastLine[v.chapter_id]);
+  });
+  const lines = [];
+  for (let ln = minLine; ln <= maxLine; ln++) {
+    if (!lineMap[ln] || !lineMap[ln].length) continue;
+    // سورةٌ تبدأ عند هذا السطر؟ أدرِج لافتةَ الاسم (والبسملة) قبله
+    let startCh = null;
+    for (const k in surahStartLine) if (surahStartLine[k] === ln) startCh = +k;
+    lines.push({ n: ln, items: lineMap[ln], center: centerLines.has(ln), startCh });
+  }
+  return { pageNum, juz, lines, verseText };
+}
+async function fetchMushafPage(p) {
+  if (_pageCache[p]) return _pageCache[p];
+  const url = 'https://api.quran.com/api/v4/verses/by_page/' + p +
+    '?words=true&word_fields=line_number,text_uthmani,char_type_name' +
+    '&fields=text_uthmani,verse_number,chapter_id,juz_number,page_number&per_page=400';
+  const res = await fetch(url);
+  if (!res.ok) throw new Error('page fetch failed');
+  const data = await res.json();
+  const model = buildPageModel(data.verses || [], p);
+  _pageCache[p] = model;
+  return model;
+}
+
+// لافتة اسم السورة — إطارٌ زخرفيّ علويّ على غرار المصحف الشريف
+function SurahBanner({ name }) {
+  return (
+    <div style={{ display: 'flex', justifyContent: 'center', margin: '6px 0 2px' }}>
+      <svg viewBox="0 0 400 64" width="100%" height="58" preserveAspectRatio="xMidYMid meet" style={{ maxWidth: 460, display: 'block' }}>
+        <rect x="6" y="10" width="388" height="44" rx="9" fill="#FBF4DF" stroke={T.green} strokeWidth="1.6" />
+        <rect x="11" y="15" width="378" height="34" rx="6" fill="none" stroke={T.gold} strokeWidth="0.9" />
+        {/* وريدات زخرفية على الطرفين */}
+        {[26, 374].map((cx, i) => (
+          <g key={i} fill="none" stroke={T.green} strokeWidth="1.2">
+            <path d={`M${cx} 19 C${cx - 8} 25 ${cx - 8} 39 ${cx} 45 C${cx + 8} 39 ${cx + 8} 25 ${cx} 19 Z`} fill="#EAF1E4" />
+            <circle cx={cx} cy="32" r="2.4" fill={T.gold} stroke="none" />
+          </g>
+        ))}
+        <text x="200" y="39" textAnchor="middle" fill={T.green}
+          style={{ font: '700 22px "Aref Ruqaa", serif' }}>سورة {name}</text>
+      </svg>
+    </div>
+  );
+}
+
+function MushafPageReader({ startPage, onExitIndex, onGoHome, fontScale, translation,
+  pageBookmark, onSetPageBookmark, saved, onToggleSaved }) {
+  const clampPage = (p) => Math.max(1, Math.min(MUSHAF_LAST_PAGE, p));
+  const [page, setPage] = React.useState(clampPage(startPage || 1));
+  const [model, setModel] = React.useState(_pageCache[clampPage(startPage || 1)] || null);
+  const [loading, setLoading] = React.useState(!_pageCache[clampPage(startPage || 1)]);
+  const [error, setError] = React.useState(false);
+  const [menu, setMenu] = React.useState(false);        // الواجهة العائمة (ضغطة واحدة)
+  const [ayahMenu, setAyahMenu] = React.useState(null); // قائمة الآية (ضغط مطوّل) {ch,vno,x,y}
+  const [tafsir, setTafsir] = React.useState(null);
+  const [toast, setToast] = React.useState(null);
+  const rootRef = React.useRef(null);
+  const toastTid = React.useRef(0);
+  const showToast = (m) => { setToast(m); clearTimeout(toastTid.current); toastTid.current = setTimeout(() => setToast(null), 2000); };
+  const fontSize = Math.round(23 * (fontScale || 1));
+
+  // جلب الصفحة + تحميل مسبق للجارتين
+  React.useEffect(() => {
+    let alive = true;
+    if (_pageCache[page]) { setModel(_pageCache[page]); setLoading(false); setError(false); }
+    else { setLoading(true); setError(false); setModel(null);
+      fetchMushafPage(page).then(m => { if (alive) { setModel(m); setLoading(false); } })
+        .catch(() => { if (alive) { setError(true); setLoading(false); } });
+    }
+    [page - 1, page + 1].forEach(p => { if (p >= 1 && p <= MUSHAF_LAST_PAGE && !_pageCache[p]) fetchMushafPage(p).catch(() => {}); });
+    return () => { alive = false; };
+  }, [page]);
+
+  const go = (delta) => { setMenu(false); setAyahMenu(null); setTafsir(null); setPage(p => clampPage(p + delta)); };
+
+  // الآيات المحفوظة على هذه الصفحة
+  const savedSet = React.useMemo(() => {
+    const s = new Set(); (saved || []).forEach(b => s.add(b.surah + ':' + b.ayah)); return s;
+  }, [saved]);
+
+  // التمييز بين النقرة والسحب والضغط المطوّل
+  const tap = React.useRef({ x: 0, y: 0, t: 0 });
+  const lp = React.useRef({ tid: 0, x: 0, y: 0, fired: false });
+  const startLP = (ch, vno, e) => {
+    const px = e.clientX, py = e.clientY;
+    clearTimeout(lp.current.tid);
+    lp.current = { x: px, y: py, fired: false, tid: setTimeout(() => {
+      lp.current.fired = true;
+      const host = rootRef.current ? rootRef.current.getBoundingClientRect() : { left: 0, top: 0 };
+      setMenu(false);
+      setAyahMenu({ ch, vno, x: px - host.left, y: py - host.top });
+      try { navigator.vibrate && navigator.vibrate(9); } catch (er) {}
+    }, 430) };
+  };
+  const moveLP = (e) => { if (Math.abs(e.clientX - lp.current.x) > 11 || Math.abs(e.clientY - lp.current.y) > 11) clearTimeout(lp.current.tid); };
+  const endLP = () => clearTimeout(lp.current.tid);
+
+  const onDown = (e) => { tap.current = { x: e.clientX, y: e.clientY, t: Date.now() }; };
+  const onUp = (e) => {
+    const s = tap.current;
+    const dx = e.clientX - s.x, dy = e.clientY - s.y, dt = Date.now() - s.t;
+    if (lp.current.fired) { lp.current.fired = false; return; }
+    if (menu || ayahMenu || tafsir) return;       // الطبقات العائمة تُغلَق بنفسها عبر خلفيّتها
+    const horiz = Math.abs(dx) > 55 && Math.abs(dx) > Math.abs(dy) * 1.4 && dt < 700;
+    if (horiz) { go(dx < 0 ? 1 : -1); return; }   // سحبٌ لليسار ← الصفحة التالية (اتجاه المصحف)
+    if (Math.abs(dx) < 10 && Math.abs(dy) < 10 && dt < 360) setMenu(true);
+  };
+
+  // التفسير/الترجمة لآية (يُعاد استعمال مصادر النظام الحالي)
+  const openTafsir = (ch, vno) => {
+    setAyahMenu(null); setMenu(false);
+    const tr = transByKey(translation);
+    setTafsir({ ch, vno, text: null, loading: true, error: false,
+      trans: tr.id ? { loading: true, text: null, error: false } : null });
+    fetchTafsir(ch, vno)
+      .then(text => setTafsir(t => (t && t.ch === ch && t.vno === vno ? { ...t, text, loading: false } : t)))
+      .catch(() => setTafsir(t => (t && t.ch === ch && t.vno === vno ? { ...t, loading: false, error: true } : t)));
+    if (tr.id) {
+      fetchTranslation(tr.id, ch)
+        .then(arr => setTafsir(t => (t && t.ch === ch && t.vno === vno ? { ...t, trans: { ...t.trans, text: arr[vno - 1] || '', loading: false } } : t)))
+        .catch(() => setTafsir(t => (t && t.ch === ch && t.vno === vno ? { ...t, trans: { ...t.trans, loading: false, error: true } } : t)));
+    }
+  };
+  const saveAyah = (ch, vno) => {
+    const was = savedSet.has(ch + ':' + vno);
+    const txt = model && model.verseText ? model.verseText[ch + ':' + vno] : '';
+    onToggleSaved && onToggleSaved(ch, vno, txt);
+    setAyahMenu(null);
+    showToast(was ? 'أُزيلت الآية من المحفوظات' : 'حُفِظت الآية في المحفوظات');
+  };
+
+  const verseTextOf = (ch, vno) => (model && model.verseText ? model.verseText[ch + ':' + vno] : '') || '';
+  const isBookmarked = pageBookmark === page;
+
+  return (
+    <div ref={rootRef} onPointerDown={onDown} onPointerUp={onUp} onPointerCancel={() => { lp.current.fired = false; }}
+      style={{ position: 'absolute', inset: 0, display: 'flex', flexDirection: 'column', background: '#FCFAF3',
+        overflow: 'hidden', WebkitUserSelect: 'none', userSelect: 'none' }}>
+
+      {/* شريط علامة الصفحة المحفوظة — يظهر في بداية الصفحة المعلَّمة فقط */}
+      {isBookmarked && (
